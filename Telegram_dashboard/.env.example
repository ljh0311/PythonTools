TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-secret

# Primary AI: Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Fallback AI: local Ollama (https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

DASHBOARD_API_KEY=dev-dashboard-key

# Human login (browser). Leave OPERATOR_PASSWORD empty for dev API-key-only mode.
OPERATOR_USERNAME=admin
OPERATOR_PASSWORD=change-me-to-a-strong-password
SESSION_TTL_HOURS=24

AUTO_REPLY_MODE=manual
TOPIC_MODE=user_type
SUMMARY_CACHE_TTL=3600
REDACTION_EXTRA_PATTERNS=

# OpenClaw (optional — configure matching values in openclaw.json skills.entries)
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

HOST=0.0.0.0
PORT=8000
