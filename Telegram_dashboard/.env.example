TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-secret

# Primary AI: Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
